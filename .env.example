# 道义现实主义社会模拟仿真系统环境变量配置示例
# 复制此文件为 .env 并填入您的实际值

# ========================================
# LLM 配置
# ========================================

# SiliconFlow API 密钥（必需）
# 从 https://siliconflow.cn/ 获取
MORAL_REALISM_LLM_API_KEY=your-api-key-here

# LLM 提供者 (siliconflow, openai, local)
MORAL_REALISM_LLM_PROVIDER=siliconflow

# LLM 模型名称
MORAL_REALISM_LLM_MODEL=deepseek-ai/DeepSeek-V3.2

# LLM API 基础 URL
MORAL_REALISM_LLM_BASE_URL=https://api.siliconflow.cn/v1

# LLM 温度参数 (0-2)
MORAL_REALISM_LLM_TEMPERATURE=0.7

# LLM 最大 token 数
MORAL_REALISM_LLM_MAX_TOKENS=4096

# ========================================
# 数据库配置
# ========================================

# 数据库文件路径
MORAL_REALISM_DATABASE_PATH=data/database.db

# ========================================
# 仿真配置
# ========================================

# 仿真总轮次 (1-1000)
MORAL_REALISM_TOTAL_ROUNDS=100

# 每轮持续时间（月）
MORAL_REALISM_ROUND_DURATION_MONTHS=6

# 领导人任期轮次
MORAL_REALISM_LEADER_TERM_ROUNDS=4

# 随机事件触发概率 (0-1)
MORAL_REALISM_RANDOM_EVENT_PROBABILITY=0.1

# 自动保存间隔（轮次）
MORAL_REALISM_AUTO_SAVE_INTERVAL=5

# ========================================
# 应用配置与其他
# ========================================

# 应用环境 (development, production, test)
APP_ENV=development

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
MORAL_REALISM_LOG_LEVEL=INFO

# 日志文件路径
MORAL_REALISM_LOG_FILE=logs/app.log

# API 主机地址
API_HOST=0.0.0.0

# API 端口
API_PORT=8000

# 最大并发请求数
MAX_CONCURRENT_REQUESTS=10

# ========================================
# 安全配置
# ========================================

# 是否要求 API 密钥认证
API_KEY_REQUIRED=false

# API 密钥列表（如果启用认证）
API_KEYS=your-api-key-here

# ========================================
# 性能配置
# ========================================

# 是否启用缓存
CACHE_ENABLED=true

# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存过期时间（秒）
CACHE_TTL=3600
