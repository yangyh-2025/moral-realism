# LLM Configuration (OpenAI-compatible API)
# Supports any OpenAI-compatible provider: OpenAI, Anthropic, Azure, Volcano Engine, etc.
# Fill in your provider details below, or use the System Config page after startup.
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=
OPENAI_API_BASE=
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY=1.0
